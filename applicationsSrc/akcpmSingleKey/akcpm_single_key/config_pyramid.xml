<!-- 
═══════════════════════════════════════════════════════════════════════════════
AKC-PM Protocol Test Configuration - Pyramid Structure
═══════════════════════════════════════════════════════════════════════════════

Structure: 3D Pyramid
- Level 0 (base): 3x3 = 9 modules
- Level 1: 2x2 = 4 modules  
- Level 2 (top): 1 module
Total: 14 modules

Initial Module (iM): Position (5,5,0) - will be BLUE
All others: Start GREY, become GREEN after authentication

Authentication Flow:
1. iM broadcasts STRUCTURE_READY to neighbors
2. Neighbors receive and initiate Algorithm 1
3. After authentication, they become GREEN and broadcast STRUCTURE_READY
4. Cascade propagation until all modules are authenticated

═══════════════════════════════════════════════════════════════════════════════
-->

<world gridSize="20,20,15" windowSize="1800,900">
    <camera target="50,50,25" directionSpherical="-20,45,100" angle="45"/>
    <spotlight target="50,50,25" directionSpherical="45,60,80" angle="40"/>
    
    <blockList color="128,128,128" blockSize="1.0,1.0,1.0">
        
        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- LEVEL 0 - BASE 3x3 (9 modules)                              -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        
        <!-- Row Y=5 -->
        <block position="5,5,0" />   <!-- ★ INITIAL MODULE (iM) ★ -->
        <block position="6,5,0" />
        <block position="7,5,0" />
        
        <!-- Row Y=6 -->
        <block position="5,6,0" />
        <block position="6,6,0" />
        <block position="7,6,0" />
        
        <!-- Row Y=7 -->
        <block position="5,7,0" />
        <block position="6,7,0" />
        <block position="7,7,0" />
        
        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- LEVEL 1 - 2x2 (4 modules)                                   -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        
        <block position="5,5,1" />
        <block position="6,5,1" />
        <block position="5,6,1" />
        <block position="6,6,1" />
        
        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- LEVEL 2 - TOP (1 module)                                    -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        
        <block position="5,5,2" />
        
    </blockList>
</world>
